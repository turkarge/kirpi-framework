# ─── Uygulama ─────────────────────────────────────────
APP_NAME="Kirpi Framework"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
KIRPI_FEATURE_COMMUNICATION=true
KIRPI_FEATURE_MONITORING=true

# ─── Veritabanı ───────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=kirpi
DB_USERNAME=kirpi
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root_secret

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Auth ─────────────────────────────────────────────
JWT_SECRET=
JWT_TTL=3600
JWT_REFRESH=604800

# ─── OpenID ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Storage ──────────────────────────────────────────
STORAGE_DRIVER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_CDN_URL=

# ─── Mail ─────────────────────────────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ─── Kirpi AI ─────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ─── Manager ──────────────────────────────────────────
MANAGER_URL=http://manager.localhost
MANAGER_SECRET=
