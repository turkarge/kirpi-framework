# Application
APP_NAME="Kirpi Framework"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

KIRPI_FEATURE_COMMUNICATION=true
KIRPI_FEATURE_MONITORING=true
KIRPI_FEATURE_AI=false
KIRPI_GIT_HASH=dev
KIRPI_READY_MAX_DB_LATENCY_MS=250
KIRPI_READY_MAX_CACHE_LATENCY_MS=150
KIRPI_RUNTIME_DASHBOARD_ENABLED=true
KIRPI_RUNTIME_DASHBOARD_IN_PRODUCTION=false

# Database
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=kirpi
DB_USERNAME=kirpi
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root_secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth
JWT_SECRET=
JWT_TTL=3600
JWT_REFRESH=604800

# OpenID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Storage
STORAGE_DRIVER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_CDN_URL=

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Kirpi AI
AI_PROVIDER=null
AI_MODEL=qwen2.5-coder:3b
AI_OLLAMA_BASE_URL=http://ollama:11434
AI_TIMEOUT=60
AI_SQL_MAX_ROWS=200
AI_SQL_DEFAULT_LIMIT=100
AI_SQL_ALLOW_TABLES=*
AI_TRACE_ENABLED=false

# Manager
MANAGER_URL=http://manager.localhost
MANAGER_SECRET=
